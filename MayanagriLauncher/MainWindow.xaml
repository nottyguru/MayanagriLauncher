<Window x:Class="MayanagriLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mayanagri Launcher" Height="420" Width="340"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="WindowBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="2">
                            <Border x:Name="PART_Indicator" Background="{TemplateBinding Foreground}" HorizontalAlignment="Left" CornerRadius="2"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#0B0D14" CornerRadius="10" MouseLeftButtonDown="Window_MouseDown" BorderBrush="#1E293B" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                <Button Content="—" Style="{StaticResource WindowBtnStyle}" Width="28" Height="28" Margin="0,0,4,0" Click="MinimizeButton_Click"/>
                <Button Content="✕" Style="{StaticResource WindowBtnStyle}" Width="28" Height="28" Click="CloseButton_Click"/>
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="260">

                <TextBlock Text="M A Y A N A G R I" Foreground="#F8FAFC" FontSize="20" FontWeight="Black" 
                           HorizontalAlignment="Center" Margin="0,0,0,40">
                    <TextBlock.Effect>
                        <DropShadowEffect ShadowDepth="3" Direction="270" Color="#000000" Opacity="0.4" BlurRadius="10"/>
                    </TextBlock.Effect>
                </TextBlock>

                <TextBlock Text="U S E R N A M E" Foreground="#64748B" FontSize="11" FontWeight="Bold" Margin="2,0,0,6"/>
                <Border x:Name="UsernameBorder" Background="#111827" CornerRadius="6" Height="42" Margin="0,0,0,24" BorderThickness="1" BorderBrush="#1F2937">
                    <TextBox x:Name="UsernameBox" Background="Transparent" Foreground="#F8FAFC" CaretBrush="#3B82F6"
                             BorderThickness="0" Padding="12,0,12,0" VerticalContentAlignment="Center" 
                             FontSize="14" FontWeight="Medium" TextChanged="UsernameBox_TextChanged" TabIndex="0"/>
                </Border>

                <Grid Margin="2,0,2,6">
                    <TextBlock Text="M E M O R Y   A L L O C A T I O N" Foreground="#64748B" FontSize="11" FontWeight="Bold" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="RamValueText" Text="4 GB" Foreground="#3B82F6" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                </Grid>
                <Slider x:Name="RamSlider" Minimum="2048" Maximum="16384" TickFrequency="1024" IsSnapToTickEnabled="True" 
                        Value="4096" Margin="0,0,0,30" ValueChanged="RamSlider_ValueChanged" Cursor="Hand"
                        Foreground="#3B82F6" TabIndex="1"/>

                <StackPanel x:Name="ProgressArea" Visibility="Collapsed" Margin="0,0,0,12">
                    <TextBlock x:Name="StatusText" Text="Initializing..." Foreground="#94A3B8" FontSize="11" FontWeight="Medium" Margin="2,0,0,6"/>
                    <ProgressBar x:Name="LaunchProgressBar" Height="4" Minimum="0" Maximum="100" Style="{StaticResource RoundedProgressBarStyle}"/>
                </StackPanel>

                <Button x:Name="PlayButton" Content="PLAY" Height="46" Style="{StaticResource PlayBtnStyle}" Click="PlayButton_Click" TabIndex="2"/>

            </StackPanel>

            <Grid Grid.Row="2" Margin="16,0,16,0">
                <Border BorderBrush="#1E293B" BorderThickness="0,1,0,0" VerticalAlignment="Top"/>
                <TextBlock Text="v1.0.0" Foreground="#475569" FontSize="11" FontWeight="SemiBold" 
                           VerticalAlignment="Center" HorizontalAlignment="Left"/>
            </Grid>
        </Grid>
    </Border>
</Window>