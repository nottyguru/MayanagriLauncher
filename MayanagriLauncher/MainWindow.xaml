<Window x:Class="MayanagriLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mayanagri Launcher" Height="440" Width="350"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="WindowBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F8FAFC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PremiumPlayBtn" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#60A5FA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" CenterX="140" CenterY="22"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#1E293B"/>
                                <Setter Property="Foreground" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkCheckBox" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="checkBoxBorder" Width="14" Height="14" Background="#0F1117" BorderBrush="#1A1F2E" BorderThickness="1" CornerRadius="3" Margin="0,0,6,0">
                                <Path x:Name="checkMark" Data="M2,7 L5,10 L11,3" Stroke="#FFFFFF" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="checkBoxBorder" Property="Background" Value="#3B82F6"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="checkMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#F8FAFC"/>
                                <Setter TargetName="checkBoxBorder" Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RepairBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="RepairText" Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#EF4444"/>
                                <Setter TargetName="RepairText" Property="TextDecorations" Value="Underline"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#0A0B0F" CornerRadius="12" MouseLeftButtonDown="Window_MouseDown" BorderBrush="#1A1F2E" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="36"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                <Button Content="—" Style="{StaticResource WindowBtnStyle}" Width="24" Margin="0,0,8,0" Click="MinimizeButton_Click"/>
                <Button Content="✕" Style="{StaticResource WindowBtnStyle}" Width="24" Click="CloseButton_Click"/>
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">

                <TextBlock Text="M A Y A N A G R I" Foreground="#F8FAFC" FontSize="18" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,8">
                    <TextBlock.Effect>
                        <DropShadowEffect ShadowDepth="2" Direction="270" Color="#000000" Opacity="0.5" BlurRadius="8"/>
                    </TextBlock.Effect>
                </TextBlock>

                <Border Height="24" Margin="0,0,0,8">
                    <TextBlock x:Name="ErrorText" Text="Error goes here" Foreground="#EF4444" FontSize="11" 
                               FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" 
                               TextAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" Visibility="Collapsed"/>
                </Border>

                <TextBlock Text="U S E R N A M E" Foreground="#64748B" FontSize="10" FontWeight="Bold" Margin="2,0,0,4"/>
                <Border x:Name="UsernameBorder" Background="#0F1117" CornerRadius="6" Height="40" Margin="0,0,0,16" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="BorderBrush" Value="#1A1F2E"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ElementName=UsernameBox, Path=IsKeyboardFocused}" Value="True">
                                    <Setter Property="BorderBrush" Value="#3B82F6"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBox x:Name="UsernameBox" Background="Transparent" Foreground="#F8FAFC" CaretBrush="#3B82F6"
                             BorderThickness="0" Padding="12,0,12,0" VerticalContentAlignment="Center" 
                             Typography.Kerning="True" FontSize="13" FontWeight="Medium"
                             TextChanged="UsernameBox_TextChanged" TabIndex="0"
                             ToolTip="Enter your Minecraft username (no spaces)"/>
                </Border>

                <Grid Margin="2,0,2,4">
                    <TextBlock Text="M E M O R Y" Foreground="#64748B" FontSize="10" FontWeight="Bold" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="RamValueText" Text="4 GB" Foreground="#3B82F6" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                </Grid>
                <Slider x:Name="RamSlider" Minimum="2048" Maximum="12288" TickFrequency="1024" IsSnapToTickEnabled="True" 
                        Value="4096" Margin="0,0,0,16" ValueChanged="RamSlider_ValueChanged" Cursor="Hand"
                        Foreground="#3B82F6" TabIndex="1" ToolTip="Recommended: 4-6 GB"/>

                <Rectangle Height="1" Fill="#1A1F2E" Margin="0,0,0,12"/>

                <Grid Margin="2,0,2,16">
                    <CheckBox x:Name="CloseAfterLaunchCheck" Content="Auto-close launcher" 
                              Style="{StaticResource DarkCheckBox}" HorizontalAlignment="Left"/>

                    <Button x:Name="RepairBtn" Content="Repair client" Style="{StaticResource RepairBtnStyle}" 
                            HorizontalAlignment="Right" Click="RepairButton_Click"
                            ToolTip="Force redownload of game files"/>
                </Grid>

                <StackPanel x:Name="ProgressArea" Opacity="0" Visibility="Hidden" Margin="0,0,0,12" Height="36">
                    <TextBlock x:Name="ProgressText" Text="Preparing engine..." Foreground="#94A3B8" FontSize="10" 
                               FontWeight="Medium" HorizontalAlignment="Left" Margin="2,0,0,6"/>

                    <ProgressBar x:Name="GameProgressBar" Height="3" Minimum="0" Maximum="100" BorderThickness="0">
                        <ProgressBar.Template>
                            <ControlTemplate TargetType="ProgressBar">
                                <Border x:Name="PART_Track" Background="#0F1117" CornerRadius="1.5">
                                    <Border x:Name="PART_Indicator" Background="#3B82F6" CornerRadius="1.5" HorizontalAlignment="Left"/>
                                </Border>
                            </ControlTemplate>
                        </ProgressBar.Template>
                    </ProgressBar>
                </StackPanel>

                <Button x:Name="PlayButton" Content="PLAY" Height="44" Style="{StaticResource PremiumPlayBtn}"
                        Click="PlayButton_Click" TabIndex="2"/>

            </StackPanel>

            <StackPanel Grid.Row="2" x:Name="ServerStatusPanel" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" ToolTip="Checking connection...">
                <Ellipse x:Name="ServerStatusLight" Width="8" Height="8" Fill="#64748B" Margin="0,1,8,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="VersionText" Text="Fetching version..." Foreground="#475569" FontSize="10" FontWeight="Medium"/>
            </StackPanel>

        </Grid>
    </Border>
</Window>