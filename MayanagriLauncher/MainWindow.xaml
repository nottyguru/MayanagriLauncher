<Window x:Class="MayanagriLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mayanagri Launcher" Height="380" Width="320"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="FlatBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                    <Setter Property="Background" Value="#334155"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#1E293B"/>
                    <Setter Property="Foreground" Value="#475569"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#0F172A" CornerRadius="8" MouseLeftButtonDown="DragWindow" BorderBrush="#334155" BorderThickness="1">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="—" Style="{StaticResource FlatBtn}" Width="30" Height="25" Click="MinimizeApp"/>
                <Button Content="✕" Style="{StaticResource FlatBtn}" Width="30" Height="25" Click="CloseApp" Margin="5,0,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock Text="M A Y A N A G R I" Foreground="#F8FAFC" FontSize="24" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBlock Text="USERNAME" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                <Border Background="#1E293B" CornerRadius="6" Height="40" Margin="0,0,0,20">
                    <TextBox x:Name="UsernameBox" Background="Transparent" Foreground="#F8FAFC" BorderThickness="0" Padding="10,0" VerticalContentAlignment="Center" FontSize="14" TextChanged="UsernameBox_TextChanged"/>
                </Border>

                <Grid Margin="0,0,0,5">
                    <TextBlock Text="RAM ALLOCATION" Foreground="#94A3B8" FontSize="11" FontWeight="Bold" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="RamValueText" Text="4 GB" Foreground="#3B82F6" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                </Grid>
                <Slider x:Name="RamSlider" Minimum="2048" Maximum="12288" TickFrequency="1024" IsSnapToTickEnabled="True" Value="4096" ValueChanged="RamSlider_ValueChanged" Foreground="#3B82F6" Margin="0,0,0,25"/>

                <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,15">
                    <TextBlock x:Name="StatusText" Text="Loading..." Foreground="#94A3B8" FontSize="11" Margin="0,0,0,5"/>
                    <ProgressBar x:Name="ProgressBar" Height="4" BorderThickness="0" Foreground="#3B82F6" Background="#1E293B"/>
                </StackPanel>

                <Button x:Name="PlayBtn" Content="PLAY" Height="45" Style="{StaticResource ActionBtn}" Click="PlayBtn_Click"/>
            </StackPanel>

            <TextBlock x:Name="VersionText" Grid.Row="2" Text="v1.0.0" Foreground="#475569" FontSize="10" HorizontalAlignment="Left" VerticalAlignment="Bottom"/>
        </Grid>
    </Border>
</Window>